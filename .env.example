# Copy to .env and fill in real values

# Supabase Transaction Pooler URL (port 6543 + ssl=require)
# Find it: Supabase dashboard → Settings → Database → Connection string → URI (Transaction mode)
# Replace postgresql:// with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?ssl=require

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DAILY_FINE_RATE=500.0
TAX_RATE=0.18

# Comma-separated frontend origins (no spaces)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
